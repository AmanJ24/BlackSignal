# ==========================================
# 🔐 SECURITY CONFIGURATION
# ==========================================

# --- TOR CONFIGURATION ---
TOR_PASSWORD=your_tor_password
TOR_CONTROL_PORT=9051
TOR_SOCKS_PORT=9050
TOR_SOCKS_HOST=127.0.0.1

# Set to False to require Tor for all operations (production)
# Set to True to allow direct clearnet fallback when Tor is unavailable (development)
ALLOW_CLEARNET_FALLBACK=True

# --- THREAT INTELLIGENCE APIS (FREE TIERS) ---
VIRUSTOTAL_API_KEY=your_virustotal_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
SHODAN_API_KEY=your_shodan_key_here

# --- DASHBOARD SECURITY ---
FLASK_SECRET_KEY=change_this_to_a_random_string_for_security
FLASK_ENV=development
CORS_ORIGINS=http://localhost:8080
# Uncomment to enable HTTP Basic Auth on the dashboard:
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=your_secure_password_here
