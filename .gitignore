# ==========================================
# BlackSignal .gitignore
# ==========================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl

# --- Virtual Environment ---
venv/
.venv/
env/
ENV/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# --- Secrets & Config ---
.secrets.env
.env
*.pem
*.key

# --- Pipeline Data (regenerated on each run) ---
data/raw/
data/normalized/
data/enriched/
data/intelligence/

# --- Logs ---
logs/
*.log

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# --- Code Review Graph (local tooling) ---
.code-review-graph/

# --- Claude / AI tooling ---
.claude/

# --- Misc ---
*.bak
*.tmp
*.orig
